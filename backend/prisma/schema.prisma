generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                 String              @id @default(uuid())
  name               String
  industry           String
  size               String
  selectedFrameworks String[]
  contactName        String?
  contactEmail       String?
  assignedConsultantId String?
  reviewStatus       ReviewStatus        @default(NOT_REVIEWED)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  assignedConsultant User?               @relation("ConsultantAssignments", fields: [assignedConsultantId], references: [id])
  assessments        Assessment[]
  evidence           Evidence[]
  remediationActions RemediationAction[]
  reports            Report[]
  users              User[]
  notes              Note[]
}

model User {
  id               String              @id @default(uuid())
  fullName         String
  email            String              @unique
  passwordHash     String
  organizationId   String?
  role             Role                @default(VIEWER)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  uploadedEvidence Evidence[]
  assignedActions  RemediationAction[] @relation("ActionOwner")
  generatedReports Report[]
  organization     Organization?       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  consultantOrgs   Organization[]      @relation("ConsultantAssignments")
  createdNotes     Note[]
  reviewedEvidence Evidence[]          @relation("EvidenceReviewer")
}

model Assessment {
  id                 String              @id @default(uuid())
  organizationId     String
  overallScore       Int
  maturityLevel      String
  riskLevel          String
  reviewStatus       ReviewStatus        @default(NOT_REVIEWED)
  date               DateTime            @default(now())
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  gaps               Gap[]
  remediationActions RemediationAction[]
  notes              Note[]              @relation("AssessmentNotes")
}

model Gap {
  id                     String             @id @default(uuid())
  assessmentId           String
  controlId              String
  controlTitle           String
  frameworks             String[]
  references             String[]
  issueSummary           String
  severity               String
  recommendedRemediation String
  suggestedEvidence      String[]
  targetTimeline         String
  assessment             Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  remediationAction      RemediationAction?
  notes                  Note[]             @relation("GapNotes")
}

model RemediationAction {
  id              String       @id @default(uuid())
  organizationId  String
  assessmentId    String
  linkedGapId     String?      @unique
  linkedControlId String?
  title           String
  description     String
  framework       String
  ownerId         String?
  dueDate         DateTime?
  status          ActionStatus @default(OPEN)
  priority        Priority     @default(MEDIUM)
  reviewStatus    ReviewStatus @default(NOT_REVIEWED)
  evidenceNotes   String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  assessment      Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  gap             Gap?         @relation(fields: [linkedGapId], references: [id])
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner           User?        @relation("ActionOwner", fields: [ownerId], references: [id])
  notes           Note[]       @relation("ActionNotes")
}

model Evidence {
  id               String       @id @default(uuid())
  organizationId   String
  uploadedByUserId String
  filename         String
  originalName     String
  mimeType         String
  fileSize         Int
  storagePath      String
  linkedEntityType String
  linkedEntityId   String
  description      String?
  reviewStatus     ReviewStatus @default(SUBMITTED)
  reviewerId       String?
  reviewedAt       DateTime?
  reviewNotes      String?
  createdAt        DateTime     @default(now())
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy       User         @relation(fields: [uploadedByUserId], references: [id])
  reviewer         User?        @relation("EvidenceReviewer", fields: [reviewerId], references: [id])
  notes            Note[]       @relation("EvidenceNotes")
}

model Report {
  id                String       @id @default(uuid())
  organizationId    String
  generatedByUserId String
  type              String
  storagePath       String
  reviewStatus      ReviewStatus @default(DRAFT)
  consultantComment String?
  createdAt         DateTime     @default(now())
  generatedBy       User         @relation(fields: [generatedByUserId], references: [id])
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  notes             Note[]       @relation("ReportNotes")
}

model Note {
  id             String       @id @default(uuid())
  organizationId String
  authorId       String
  content        String
  visibility     Visibility   @default(INTERNAL)
  linkedType     String       // ASSESSMENT, GAP, ACTION, EVIDENCE, REPORT
  linkedId       String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author         User         @relation(fields: [authorId], references: [id])
  
  assessment     Assessment?   @relation("AssessmentNotes", fields: [linkedId], references: [id], map: "Note_Assessment_fkey")
  gap            Gap?          @relation("GapNotes", fields: [linkedId], references: [id], map: "Note_Gap_fkey")
  action         RemediationAction? @relation("ActionNotes", fields: [linkedId], references: [id], map: "Note_Action_fkey")
  evidence       Evidence?     @relation("EvidenceNotes", fields: [linkedId], references: [id], map: "Note_Evidence_fkey")
  report         Report?       @relation("ReportNotes", fields: [linkedId], references: [id], map: "Note_Report_fkey")
}

model FrameworkPack {
  id                 String   @id @default(uuid())
  slug               String   @unique // iso-42001, eu-ai-act
  name               String
  description        String
  status             String   @default("DRAFT") // DRAFT, ACTIVE, ARCHIVED
  metadata           Json?    // For custom mappings or roadmap templates
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model PublicAssessmentSession {
  id                      String              @id @default(uuid())
  status                  PublicSessionStatus @default(STARTED)
  startedAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  completedAt             DateTime?
  expiresAt               DateTime
  organizationName        String?
  industry                String?
  companySize             String?
  selectedFrameworks      String[]
  answers                 Json?
  overallScore            Int?
  maturityLevel           String?
  riskLevel               String?
  summarySnapshot         Json?
  convertedAt             DateTime?
  convertedAssessmentId   String?
  convertedOrganizationId String?
  convertedUserId         String?
}

enum Role {
  SUPER_ADMIN
  CONSULTANT
  ORG_ADMIN
  ASSESSOR
  VIEWER
}

enum ActionStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  COMPLETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PublicSessionStatus {
  STARTED
  IN_PROGRESS
  COMPLETED
  EXPIRED
}

enum ReviewStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  ACCEPTED
  REJECTED
  NEEDS_CHANGES
  NOT_REVIEWED
  CLIENT_FOLLOWUP_NEEDED
}

enum Visibility {
  INTERNAL
  CLIENT_VISIBLE
}

